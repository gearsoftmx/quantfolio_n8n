    {
      "parameters": {
        "jsCode": "const API_KEY = '72a341c34753f332e7d4e13864a3affa9693e4199687156ed8b544ba7677acfd';\nconst START_DATE = '1990-01-01'; // Ojo: Banxico tiene datos desde 1954 para USD, pero otras son más recientes\nconst END_DATE = '2026-02-15';\n\nconst series_config = {\n  // --- DÓLAR (USD) ---\n  // Banxico da \"Pesos por Dólar\". No se invierte.\n  'SF43718': { from: 'USD', to: 'MXN', rate_type: 'FIX', inverse: false },\n  'SF60653': { from: 'USD', to: 'MXN', rate_type: 'SPOT', inverse: false },\n  'SF343410': { from: 'USD', to: 'MXN', rate_type: 'CLOSE', inverse: false },\n\n  // --- OTRAS DIVISAS ---\n  // Banxico da \"Pesos por Euro\", \"Pesos por Yen\", etc. No se invierte.\n  'SF46410': { from: 'EUR', to: 'MXN', rate_type: 'FIX', inverse: false },\n  'SF46406': { from: 'JPY', to: 'MXN', rate_type: 'FIX', inverse: false }, // Dato: ~0.13 MXN\n  'SF46407': { from: 'GBP', to: 'MXN', rate_type: 'FIX', inverse: false },\n  'SF60632': { from: 'CAD', to: 'MXN', rate_type: 'FIX', inverse: false },\n  \n  // --- UDIs e INFLACIÓN ---\n  // Banxico da \"Pesos por UDI\". No se invierte.\n  'SP68257': { from: 'UDI', to: 'MXN', rate_type: 'INFLATION', inverse: false },\n  \n  // --- OTRAS ---\n  'SF290383': { from: 'CNY', to: 'MXN', rate_type: 'FIX', inverse: false }\n};\n\nreturn Object.entries(series_config).map(([series_id, config]) => ({\n  json: {\n    series_id: series_id,\n    api_key: API_KEY,\n    start_date: START_DATE,\n    end_date: END_DATE,\n    from_currency: config.from,\n    to_currency: config.to,\n    rate_type: config.rate_type,\n    inverse: config.inverse // Aquí pasamos el false explícitamente\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        256
      ],
      "id": "2eeacbbd-0261-459b-9baf-d348882318b0",
      "name": "parametros banxico"
    },
    {
      "parameters": {
        "jsCode": "const API_KEY = 'e28c7bf00d9418ff0e3668963ea8a915';\nconst START_DATE = '1990-01-01'; \nconst END_DATE = '2026-02-15';\n\nconst series_config = {\n  // --- GRUPO 1: El dato ya viene en Dólares (USD por moneda) ---\n  // inverse: false\n  'DEXUSEU': { from: 'EUR', to: 'USD', rate_type: 'SPOT', inverse: false }, // Euro\n  'DEXUSUK': { from: 'GBP', to: 'USD', rate_type: 'SPOT', inverse: false }, // Libra\n  'DEXUSAL': { from: 'AUD', to: 'USD', rate_type: 'SPOT', inverse: false }, // Australia\n\n  // --- GRUPO 2: El dato viene en \"Moneda por Dólar\" ---\n  // inverse: true (1 / rate)\n  'DEXJPUS': { from: 'USD', to: 'JPY', rate_type: 'SPOT', inverse: true }, // Yen\n  'DEXSZUS': { from: 'USD', to: 'CHF', rate_type: 'SPOT', inverse: true }, // Suiza\n  'DEXCAUS': { from: 'USD', to: 'CAD', rate_type: 'SPOT', inverse: true }, // Canadá\n  'DEXCHUS': { from: 'USD', to: 'CNY', rate_type: 'SPOT', inverse: true }, // China\n  'DEXBZUS': { from: 'USD', to: 'BRL', rate_type: 'SPOT', inverse: true }, // Brasil\n  'DEXKOUS': { from: 'USD', to: 'KRW', rate_type: 'SPOT', inverse: true }  // Corea\n};\n\nreturn Object.entries(series_config).map(([series_id, config]) => ({\n  json: {\n    series_id: series_id,\n    api_key: API_KEY,\n    start_date: START_DATE,\n    end_date: END_DATE,\n    from_currency: config.from,\n    to_currency: config.to,\n    rate_type: config.rate_type, // Ahora dirá 'SPOT'\n    inverse: config.inverse \n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
