      "disabled": true
    },
    {
      "parameters": {
        "jsCode": "const allItems = [];\n\nfor (const item of $input.all()) {\n  // 1. Obtener datos de configuración originales\n  const from_currency = item.json.from_currency;\n  const to_currency = item.json.to_currency;\n  const rate_type = item.json.rate_type;\n  \n  // Leemos la bandera 'inverse' para pasarla al resultado\n  const is_inverse = item.json.inverse === true; \n  \n  // 2. Determinar la fuente y extraer observaciones\n  let observations = [];\n  let provider_id = '';\n  \n  // Estructura de Banxico\n  if (item.json.bmx && item.json.bmx.series && item.json.bmx.series[0]) {\n    observations = item.json.bmx.series[0].datos || [];\n    provider_id = 'banxico';\n  }\n  // Estructura de FRED\n  else if (item.json.observations) {\n    observations = item.json.observations;\n    provider_id = 'fred';\n  }\n  \n  // 3. Procesar las observaciones\n  for (const obs of observations) {\n    let raw_rate = 0;\n    let rate_date = '';\n\n    // --- LÓGICA BANXICO ---\n    if (provider_id === 'banxico') {\n      if (!obs.dato || obs.dato === 'N/E') continue;\n      \n      // Limpiar comas y parsear\n      raw_rate = parseFloat(obs.dato.replace(/,/g, ''));\n      rate_date = obs.fecha; \n      \n      // Normalizar Fecha (DD/MM/YYYY -> YYYY-MM-DD)\n      if (rate_date.includes('/')) {\n        const [d, m, y] = rate_date.split('/');\n        rate_date = `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}`;\n      }\n    } \n    \n    // --- LÓGICA FRED ---\n    else if (provider_id === 'fred') {\n      if (!obs.value || obs.value === '.') continue;\n      \n      raw_rate = parseFloat(obs.value);\n      rate_date = obs.date; \n    }\n\n    // 4. Validar número\n    if (isNaN(raw_rate) || raw_rate <= 0) continue;\n\n    // 5. GUARDAR RESULTADO (SIN INVERTIR)\n    // Se guarda el dato crudo y las etiquetas originales.\n    allItems.push({\n      json: {\n        from_currency: from_currency,\n        to_currency: to_currency,\n        rate_type: rate_type,\n        provider_id: provider_id,\n        rate_date: rate_date,\n        \n        rate: raw_rate,          // Valor original (ej. 150.00 para JPY)\n        is_inverse: is_inverse   // Bandera para saber que este dato es \"inverso\"\n      }\n    });\n  }\n}\n\nconsole.log(`Total items procesados: ${allItems.length}`);\n\nreturn allItems;"
      },
