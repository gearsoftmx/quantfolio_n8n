    {
      "parameters": {
        "jsCode": "const allItems = [];\n\nfor (const item of $input.all()) {\n  // Obtener datos del item actual\n  const from_currency = item.json.from_currency;\n  const to_currency = item.json.to_currency;\n  const rate_type = item.json.rate_type;\n  \n  // Obtener series de Banxico o FRED según la estructura\n  let observations = [];\n  \n  // Estructura de Banxico\n  if (item.json.bmx && item.json.bmx.series && item.json.bmx.series[0]) {\n    observations = item.json.bmx.series[0].datos || [];\n  }\n  // Estructura de FRED\n  else if (item.json.observations) {\n    observations = item.json.observations;\n  }\n  \n  console.log(`Processing ${from_currency}/${to_currency} (${rate_type}): ${observations.length} observations`);\n  \n  for (const obs of observations) {\n    // Para Banxico\n    if (obs.dato) {\n      if (obs.dato === 'N/E' || !obs.dato) continue;\n      \n      const rate = parseFloat(obs.dato.replace(/,/g, ''));\n      if (isNaN(rate) || rate <= 0) continue;\n      \n      // Normalizar fecha de Banxico\n      let rate_date = obs.fecha;\n      \n      // Formato YYYYMMDD -> YYYY-MM-DD\n      if (/^\\d{8}$/.test(rate_date)) {\n        rate_date = `${rate_date.slice(0,4)}-${rate_date.slice(4,6)}-${rate_date.slice(6,8)}`;\n      }\n      // Formato DD/MM/YYYY -> YYYY-MM-DD\n      else if (rate_date.includes('/')) {\n        const [d, m, y] = rate_date.split('/');\n        rate_date = `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}`;\n      }\n      \n      allItems.push({\n        json: {\n          from_currency: from_currency,\n          to_currency: to_currency,\n          rate_type: rate_type,\n          provider_id: 'banxico',\n          rate_date: rate_date,\n          rate: rate\n        }\n      });\n    }\n    // Para FRED\n    else if (obs.value) {\n      if (obs.value === '.' || !obs.value) continue;\n      \n      const rate = parseFloat(obs.value);\n      if (isNaN(rate) || rate <= 0) continue;\n      \n      allItems.push({\n        json: {\n          from_currency: from_currency,\n          to_currency: to_currency,\n          rate_type: rate_type,\n          provider_id: 'fred',\n          rate_date: obs.date,  // FRED ya viene en YYYY-MM-DD\n          rate: rate\n        }\n      });\n    }\n  }\n}\n\nconsole.log(`Total items procesados: ${allItems.length}`);\n\nreturn allItems;"
      },
