      "parameters": {
        "jsCode": "function convertirFecha(fechaBanxico) {\n  const [dia, mes, año] = fechaBanxico.split('/');\n  return `${año}-${mes.padStart(2, '0')}-${dia.padStart(2, '0')}`;\n}\n\nconst allItems = [];\n\nfor (const item of $input.all()) {\n  const series = item.json.bmx?.series?.[0];\n  \n  if (!series || !series.datos) {\n    continue;\n  }\n  \n  for (const dato of series.datos) {\n    try {\n      allItems.push({\n        json: {\n          from_currency: 'MXN',\n          to_currency: 'EUR',\n          rate_type: 'FIX',\n          provider_id: 'banxico',\n          rate_date: convertirFecha(dato.fecha),\n          rate: parseFloat(dato.dato)\n        }\n      });\n    } catch (error) {\n      console.error('Error procesando dato:', dato, error);\n    }\n  }\n}\n\nreturn allItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
